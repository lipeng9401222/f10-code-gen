/**
 * list-model.js.tmpl · 列表页数据模型骨架
 *
 * 用法：cp 到目标 .vue 的 <script setup> 内，按 <FILL: ...> 标记替换。
 * 占位符两类：
 *   {{NAME}} {{MODULE}} ...    机械替换（sed 一次搞定）
 *   <FILL: ...>                必须 Agent / 人工判断后填，不能批量替换
 *
 * 来源：vue-docs/page-examples/base/list.vue + rules/data-model-rules.md
 */

import { ref, computed, onMounted, onActivated } from 'vue';
import { Utils, Hooks } from '@epframe/eui-core';

const { useTableModel, useListModel, useTreeModel } = Hooks;
const { createSubModel, PageConfig, request } = Utils;

// 页面配置模型
const pageConfig = new PageConfig({});

// 定义数据模型
const model = Utils.defineDataModel(() => {
  // 选中行 keys
  const selectedRowKeys = ref([]);

  // 搜索条件子模型
  const searchParams = createSubModel(
    {
      logicOperator: 'and',
      conditions: []
    },
    {
      update: (params) => {
        searchParams.data.conditions = params.conditions;
        searchParams.data.logicOperator = params.logicOperator;
      }
    }
  );

  // <FILL: 列举页面用到的所有枚举字段，每个一个 useListModel>
  // 例：审核状态、分类、状态等
  // const reviewStateList = useListModel('/api/{{MODULE}}/{{APPNAME}}/reviewStateOptions', {
  //   labelField: 'label',
  //   lazy: false
  // });

  // 主列表
  const gridList = useTableModel('/api/{{MODULE}}/{{APPNAME}}/list', {
    idField: 'id',
    lazy: false,
    params: computed(() => ({
      ...searchParams.data
      // <FILL: 如果有左侧树或其他筛选，加在这里>
      // category: selectedCategory.value !== 'all' ? selectedCategory.value : undefined
    }))
  });

  // <FILL: 如果 hasTree=true，加 useTreeModel>
  // const typeTree = useTreeModel('/api/{{MODULE}}/{{APPNAME}}/tree', {
  //   lazy: false
  // });

  return {
    global: { pageConfig },
    models: {
      searchParams,
      // <FILL: 这里把上面声明的所有 useListModel / useTableModel / useTreeModel / ref 都加进来>
      // reviewStateList,
      gridList,
      // typeTree,
      selectedRowKeys
    }
  };
});

