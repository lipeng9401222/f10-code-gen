// 弹窗关闭（来源：dialog-interaction.md § 3.3）
const getCurrentDialog = inject('getCurrentDialog');
const closeDialog = (action = 'close', data) => {
  getCurrentDialog()?.close(action === 'close' ? action : data);
};

// 表单引用
const formRef = ref(null);

// 表单数据
